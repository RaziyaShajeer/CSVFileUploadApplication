@model CSVFileApplication.API.UserModule.SignUpRequest

@{
    // Check if the session is null
    var userEmail = Context.Session.GetString("UserName");
    Layout = string.IsNullOrEmpty(userEmail) ? null : "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Register";
}
@if (string.IsNullOrEmpty(userEmail))
{
    <!-- Include Bootstrap if layout is skipped -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
}
<!-- Full page background -->
<div class="d-flex align-items-center vh-100 " style="margin-left:80px;">
    <div class="card shadow-lg p-4" style="width: 100%; max-width: 450px; border-radius: 1rem;padding:400px;">
        <div class="text-center mb-4">
            <h1 class="fw-bold text-primary">Register</h1>
            <p class="text-muted">Create your account</p>
        </div>

        <form asp-action="SignUp" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="form-floating mb-3">
                <input asp-for="Name" class="form-control" placeholder="Username" />
                <label asp-for="Name">Username</label>
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="form-floating mb-3">
                <input asp-for="Email" class="form-control" placeholder="Email" />
                <label asp-for="Email">Email</label>
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="form-floating mb-3">
                <input asp-for="Password" class="form-control" placeholder="Password" type="password" />
                <label asp-for="Password">Password</label>
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <div class="d-grid mb-3">
                <button type="submit" class="btn btn-gradient btn-primary btn-lg fw-bold">Create Account</button>
            </div>

            <div class="text-center">
                <a asp-action="Login" asp-controller="Authentication" class="text-decoration-none">Login</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

<style>
    /* Gradient button */
    .btn-gradient {

        color: #fff;
        transition: 0.3s;
    }

        .btn-gradient:hover {

            color: #fff;
        }

    /* Optional: Smooth input focus */
    .form-control:focus {
        box-shadow: 0 0 0 0.2rem rgba(102, 126, 234, 0.25);
        border-color: #667eea;
    }

    /* Card shadow */
    .card {
        background-color: #fff;
    }
</style>