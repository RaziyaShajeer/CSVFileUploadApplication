<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - UserApplication</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        body {
            overflow-x: hidden;
            margin: 0;
            padding: 0;
        }

        .sidebar {
            position: fixed;
            top: 0;
            left: 0;
            width: 240px;
            height: 100vh;
            background-color: #2c3e50;
            padding: 20px;
            overflow-y: auto;
            z-index: 100;
        }

            .sidebar h1 {
                color: whitesmoke;
                font-size: 1.5rem;
                margin-bottom: 20px;
            }

            .sidebar .nav-link {
                color: #ccc;
                padding: 10px 12px;
                border-radius: 6px;
                display: block;
                margin-bottom: 4px;
                transition: background 0.2s, color 0.2s;
            }

                .sidebar .nav-link:hover {
                    background-color: #3d5166;
                    color: white;
                    text-decoration: none;
                }

                /* Active highlight */
                .sidebar .nav-link.active {
                    background-color: #1a73e8;
                    color: white !important;
                    font-weight: 600;
                }

        .content-area {
            margin-left: 240px;
            padding: 20px;
            width: calc(100% - 240px);
            box-sizing: border-box;
            overflow-x: hidden;
            min-height: 100vh;
        }

        footer {
            margin-left: 240px;
            padding: 10px 20px;
        }
    </style>
</head>

@{
            var currentController = ViewContext.RouteData.Values["Controller"]?.ToString();
            var currentAction = ViewContext.RouteData.Values["Action"]?.ToString();
}

<body>
    <div class="sidebar">
        <h1>UserApp</h1>
        <ul class="navbar-nav">
            <li class="nav-item">
                <a class="nav-link @(currentController == "Dashboard" && currentAction == "ViewDashboard" ? "active" : "")"
                   asp-controller="Dashboard"
                   asp-action="ViewDashboard">
                    Dashboard
                </a>
            </li>
            
            <li class="nav-item">
                <a class="nav-link @(currentController == "Authentication" && currentAction == "Logout" ? "active" : "")"
                   asp-controller="Authentication"
                   asp-action="Logout">
                    Signout
                </a>
            </li>
        </ul>
    </div>

    <div class="content-area">
        @RenderBody()
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>